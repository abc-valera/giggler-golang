# This is an example of a dev.env file for the development.
#
# It contains all the environment variables, that are used in the application,
# with the all possible values, that can be set.

# dev | prod | test
APP_MODE=dev

# URL specifies the URL to access the application from the browser
URL=http://localhost:3000

# slog_stdout | nop
LOGGER=slog_stdout

TRACER= # 

DB=gorm
SQLITE_PATH=./local/db.sqlite3

FS=local
FS_LOCAL_PATH=./local/files

EMAILER=dummy

### View ENV ###

PORT=3000

JWT_SIGN_KEY=01234567890123456789012345678901
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=24h